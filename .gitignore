# NewDriver .gitignore

# Entire directories excluded from GitHub
Dataset/
scripts/

# Images and photos (not uploaded to GitHub)
*.jpg
*.jpeg
*.png
*.bmp
*.gif
*.tiff
*.webp

# Dataset folders with images
Dataset/png/
Dataset/labelledImg/*.jpg
Dataset/labelledImg/*.png
Dataset/YOLO_Ready/train/images/
Dataset/YOLO_Ready/val/images/
Gen/img/
Gen/Collections/
Gen/labelImg/*.jpg
Gen/labelImg/*.png

# Trained models (too large)
*.pt
training/runs/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/

# Environments
.env
.venv
venv/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Jupyter
.ipynb_checkpoints/

# Logs
*.log
logs/

# Game captures
captures/

# YOLO cache
*.cache
labels.cache
Gen/
